# Network specific env vars
# Uncomment section for relevant network
## MAINNET #
RPC_URL=https://api.circuitdao.com # mainnet
ADD_SIG_DATA="ccd5bb71183532bff220ba46c268991a3ff07eb358e8255a65c30a2dce0e5fbb"
## TESTNET #
#RPC_URL=https://testnet-api.circuitdao.com # Base URL for the Circuit RPC API server
#ADD_SIG_DATA="37a90eb5185a9c4439a91ddc98bbadce7b4feba060d50116a067de66bf236615"
## SIMULATOR #
#RPC_URL="http://localhost:8000"
#ADD_SIG_DATA="ccd5bb71183532bff220ba46c268991a3ff07eb358e8255a65c30a2dce0e5fbb"

# Global env vars
PRIVATE_KEY=  # <<<Enter here or comment out and export manually>>>
OKX_API_DEMO_TRADING_KEY= # <<<Enter here>>>
OKX_API_DEMO_TRADING_SECRET= # <<<Enter here>>>
OKX_API_DEMO_TRADING_PASSPHRASE= # <<<Enter here>>>
OKX_API_LIVE_TRADING_KEY= # <<<Enter here>>>
OKX_API_LIVE_TRADING_SECRET= # <<<Enter here>>>
OKX_API_LIVE_TRADING_PASSPHRASE= # <<<Enter here>>>
FEE_PER_COST="fast"
# Number of wallet addresses (synthetic keys) each bot derives and scans for coins. Keepers usually hold CRT/XCH on the first indexes, so a low count (eg 1-20) is enough and avoids scanning many empty addresses (which can trip the node's per-wallet coin-fetch limit or time out). blank = 500
KEY_COUNT=
OKX_URL=wss://ws.okx.com:8443/ws/v5/public # Base URL for OKX v5 API

# Bot specific env vars

### announcer configure bot ###
ANNOUNCER_CONFIGURE_RUN_INTERVAL=300
ANNOUNCER_CONFIGURE_CONTINUE_DELAY=10
ANNOUNCER_CONFIGURE_CONFIGURE_UNAPPROVED_ANNOUNCER="true"
ANNOUNCER_CONFIGURE_DEPOSIT_BUFFER=1.0 # in XCH
ANNOUNCER_CONFIGURE_DEPOSIT_BUFFER_REFILL_THRESHOLD=0.2 # 1.0 = 100%

### announcer update bot ###
ANNOUNCER_UPDATE_RUN_INTERVAL=60
ANNOUNCER_UPDATE_CONTINUE_DELAY=10
ANNOUNCER_UPDATE_TTL_BUFFER=30
ANNOUNCER_UPDATE_UPDATE_THRESHOLD_BPS=5
ANNOUNCER_UPDATE_STARTUP_WINDOW=10 # Length of start-up window in seconds
ANNOUNCER_UPDATE_AVERAGE_WINDOW=3600 # Length of window over which to calculate volume-weighted average price in seconds

### announcer rewards bot ###
ANNOUNCER_REWARDS_RUN_INTERVAL=60
ANNOUNCER_REWARDS_CONTINUE_DELAY=10
ANNOUNCER_REWARDS_TARGET_PUZZLE_HASH="" # Inner puzzle hash at which to receive CRT rewards. If not specified, announcer's inner puzzle hash is used

### announcer penalize bot ###
ANNOUNCER_PENALIZE_RUN_INTERVAL=60
ANNOUNCER_PENALIZE_CONTINUE_DELAY=10

### savings bot ###
SAVINGS_CONTINUE_DELAY=10
SAVINGS_RUN_INTERVAL=600
SAVINGS_MAX_NUM_RUNS=60
SAVINGS_TIMEZONE="Europe/London"
SAVINGS_YEAR=*
SAVINGS_MONTH=*
SAVINGS_DAY_OF_WEEK=*
SAVINGS_DAY=*
SAVINGS_HOUR=*
SAVINGS_MINUTE=*
SAVINGS_SECOND=random
SAVINGS_START_DATE=
SAVINGS_END_DATE=

### SF transfer bot ###
SF_TRANSFER_CONTINUE_DELAY=10
SF_TRANSFER_RUN_INTERVAL=60
SF_TRANSFER_MIN_AMOUNT=1000 # Don't transfer if accrued SFs are less than this. given in mBYC

### liquidation start bot ###
LIQUIDATION_START_CONTINUE_DELAY=5
LIQUIDATION_START_RUN_INTERVAL=20
LIQUIDATION_START_INITIATOR_PUZZLE_HASH=

### liquidation bid bot ###
LIQUIDATION_CONTINUE_DELAY=10
LIQUIDATION_RUN_INTERVAL=30
LIQUIDATION_COLLATERAL_RATIO_PCT=500 # This should always be significantly larger than Liquidation Ratio. given in percentage points (eg 500 = 500%)
LIQUIDATION_MAX_BID_AMOUNT=
LIQUIDATION_MARGIN=0.1 # Margin. given as float (eg 0.1 = 10% margin)

### bad debt recovery bot ###
BAD_DEBT_RECOVERY_CONTINUE_DELAY=3600
BAD_DEBT_RECOVERY_RUN_INTERVAL=21600 # run every 6 hours

### governance implement bot ###
IMPLEMENT_RUN_INTERVAL=3600
IMPLEMENT_CONTINUE_DELAY=60

### recharge start settle bot ###
RECHARGE_START_SETTLE_CONTINUE_DELAY=10
RECHARGE_START_SETTLE_RUN_INTERVAL=60

### surplus start settle bot ###
SURPLUS_START_SETTLE_CONTINUE_DELAY=10
SURPLUS_START_SETTLE_RUN_INTERVAL=60

### surplus bid bot ###
SURPLUS_BID_CONTINUE_DELAY=10
SURPLUS_BID_RUN_INTERVAL=30
# Min CRT/BYC price (ie BYC per CRT) the BYC lot must value each bid CRT at. given as float (may be fractional, eg 0.001). blank = just bid the minimum increment
SURPLUS_BID_MIN_CRT_PRICE=
# CRT/BYC price (ie BYC per CRT) at which to open bidding to speed up the auction. given as float. blank = start at the minimum increment
SURPLUS_BID_STARTING_CRT_PRICE=
# Absolute cap on CRT bid for the BYC lot. given in mCRT. blank = no cap
SURPLUS_BID_MAX_CRT_AMOUNT=
# Inner puzzle hash at which to receive the BYC lot if won. blank = keeper's own puzzle hash
SURPLUS_BID_TARGET_PUZZLE_HASH=

### recharge bid bot ###
RECHARGE_BID_CONTINUE_DELAY=10
RECHARGE_BID_RUN_INTERVAL=30
# Max CRT/BYC price (ie BYC per CRT) we will pay for the CRT we receive. given as float (may be fractional, eg 0.001). blank = just bid the minimum increment
RECHARGE_BID_MAX_CRT_PRICE=
# CRT/BYC price (ie BYC per CRT) at which to open bidding to speed up the auction. given as float. blank = start at the minimum increment
RECHARGE_BID_STARTING_CRT_PRICE=
# Absolute cap on BYC paid in a bid. given in mBYC. blank = no cap
RECHARGE_BID_MAX_BYC_AMOUNT=
# Inner puzzle hash at which to receive the CRT if won. blank = keeper's own puzzle hash
RECHARGE_BID_TARGET_PUZZLE_HASH=

